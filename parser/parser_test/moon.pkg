import {
  "moonbitlang/yacc/ast",
  "moonbitlang/yacc/parser",
  "moonbitlang/core/list",
  "moonbitlang/core/test",
}

rule(
  name: "embed",
  command: "moon runwasm moonbit-community/embed $input -o $output",
)

dev_build(rule: "embed", input: "../parser.mbty", output: "parser_spec_src.mbt")

dev_build(
  rule: "embed",
  input: "../../tests/ocaml_jsoncst_test/ocaml.mly",
  output: "ocaml_parser_spec_src.mbt",
)
