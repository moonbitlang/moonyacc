import {
  "moonbitlang/core/list",
}

rule(
  name: "moonyacc_tokens",
  command: "moon runwasm $mod_dir/.. -- $input --mode only-tokens | moonfmt > $output",
)

dev_build(
  rule: "moonyacc_tokens",
  input: "calc.mbty",
  output: "calc_tokens.mbt",
)

rule(
  name: "moonyacc",
  command: "moon runwasm $mod_dir/.. -- $input --external-tokens | moonfmt > $output",
)

dev_build(rule: "moonyacc", input: "calc.mbty", output: "calc.mbt")
