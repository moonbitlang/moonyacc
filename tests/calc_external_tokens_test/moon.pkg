import {
  "moonbitlang/core/list",
}

formatter(ignore: ["calc_tokens.mbt", "calc.mbt"])

rule(
  name: "moonyacc_tokens",
  command: "moon runwasm $mod_dir/.. -- $input --mode only-tokens -o $output",
)

dev_build(
  rule: "moonyacc_tokens",
  input: "calc.mbty",
  output: "calc_tokens.mbt",
)

rule(
  name: "moonyacc",
  command: "moon runwasm $mod_dir/.. -- $input --external-tokens -o $output",
)

dev_build(rule: "moonyacc", input: "calc.mbty", output: "calc.mbt")
