import {
  "moonbitlang/ulex-runtime/lexbuf",
  "moonbitlang/core/int",
  "moonbitlang/core/list",
}

import {
  "moonbitlang/core/test",
} for "wbtest"

warnings = "-2-6-text_segment_excceed"

formatter(ignore: ["binary_search.mbt", "lexer.mbt", "ocaml.mbt"])

rule(
  name: "embed",
  command: "moon runwasm moonbit-community/embed $input -o $output",
)

dev_build(rule: "embed", input: "binary_search.ml", output: "binary_search.mbt")

rule(
  name: "moonlex",
  command: "moon runwasm moonbitlang/ulex@0.3.29 $input -o $output",
)

dev_build(rule: "moonlex", input: "lexer.mbtx", output: "lexer.mbt")

rule(
  name: "moonyacc",
  command: "moon runwasm $mod_dir/.. -- --compress-table --mode json-cst --input-mode pull --force-token-no-payload --force-int-position $input -o $output",
)

dev_build(rule: "moonyacc", input: "ocaml.mly", output: "ocaml.mbt")
