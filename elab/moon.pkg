import {
  "moonbitlang/yacc/parser",
  "moonbitlang/yacc/util/array_multimap",
  "moonbitlang/yacc/util/stamp",
  "moonbitlang/yacc/ast",
  "moonbitlang/yacc/parser/type_expr_parser",
  "moonbitlang/core/immut/vector" @immut/vector,
  "moonbitlang/core/list",
  "moonbitlang/core/sorted_map",
  "moonbitlang/core/sorted_set",
}

formatter(ignore: [ "stdlib_src.mbt" ])

rule(
  name: "embed",
  command: "moon runwasm moonbit-community/embed $input -o $output",
)

dev_build(rule: "embed", input: "stdlib.mbty", output: "stdlib_src.mbt")
